# 复制为 .env 并按需覆盖

# 模型 key:dev 兜底(组织没在后台配 key 时用这个)。生产走组织 BYO-key。
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 数据库(默认指向 docker-compose 的 postgres,端口 5433 避开本机 5432)
# DATABASE_URL=postgresql+psycopg://agora_app:agora_app@localhost:5433/agora
# DATABASE_ADMIN_URL=postgresql+psycopg://agora:agora@localhost:5433/agora

# 加密各组织 key 用(生产必须换强随机值):
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# APP_SECRET_KEY=...

# 鉴权:dev 用内置 org/user 免 Clerk;生产置 false 走 Clerk
DEV_MODE=true
# CLERK_SECRET_KEY=
